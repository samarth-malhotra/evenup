{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@api/*": ["./src/api/*"],
      "@assets/*": ["./src/assets/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@features/*": ["./src/features/*"],
      "@theme/*": ["./src/theme/*"],
      "@mocks/*": ["./src/mocks/*"],
      "@components/*": ["./src/components/*"],
      "@stores/*": ["./stores/*"]
      // "@config/*": ["./config/*"]
    },

    "types": ["react", "react-native", "nativewind/types", "expo-router"],

    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true
  }
}
