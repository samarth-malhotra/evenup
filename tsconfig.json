{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["react", "react-native"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "tailwind.config.mjs",
    "babel.config.mjs"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "babel.config.mjs",
    "tailwind.config.mjs"
  ]
}
