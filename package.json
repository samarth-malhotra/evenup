{
  "name": "evenup-fe",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "sync:tokens": "node src/theme/script/sync-tailwind.js",
    "start": "cross-env APP_ENV=development npm run sync:tokens && expo start -c",
    "start:staging": "cross-env APP_ENV=staging npm run sync:tokens && expo start",
    "start:prod": "cross-env APP_ENV=production npm run sync:tokens && expo start",
    "android": "cross-env APP_ENV=development npm run sync:tokens && expo start:android",
    "ios": "cross-env APP_ENV=development expo run:ios",
    "build:android:staging": "cross-env APP_ENV=staging eas build -p android --profile preview",
    "build:android:prod": "cross-env APP_ENV=production eas build -p android --profile production",
    "a:tunnel": "cross-env APP_ENV=development npm run sync:tokens && expo start -c --tunnel --android",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "^6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.6",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.76.1",
    "@tanstack/query-async-storage-persister": "^5.90.7",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-persist-client": "^5.90.7",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.3",
    "expo": "54.0.17",
    "expo-auth-session": "^7.0.8",
    "expo-constants": "~18.0.10",
    "expo-contacts": "^15.0.10",
    "expo-crypto": "^15.0.7",
    "expo-dev-client": "^6.0.16",
    "expo-doctor": "^1.17.11",
    "expo-file-system": "^19.0.17",
    "expo-font": "^14.0.9",
    "expo-image-picker": "^17.0.8",
    "expo-linear-gradient": "^15.0.7",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.13",
    "expo-secure-store": "^15.0.7",
    "expo-sharing": "^14.0.7",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "^6.0.8",
    "expo-web-browser": "^15.0.8",
    "jotai": "^2.15.0",
    "jotai-utils": "^0.0.0",
    "libphonenumber-js": "^1.12.24",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-css-interop": "^0.2.1",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-gifted-charts": "^1.4.64",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.6.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@eslint/js": "^9.38.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.6",
    "cross-env": "^10.1.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-expo": "^1.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.5",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^3.4.18",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --ignore-pattern supabase/",
      "prettier --write"
    ],
    "*.{json,css,md}": "prettier --write"
  }
}
