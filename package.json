{
  "name": "evenup",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "expo": {},
  "scripts": {
    "start": "cross-env APP_ENV=development npm run sync:tokens && expo start -c",
    "start:staging": "cross-env APP_ENV=staging npm run sync:tokens && expo start",
    "start:prod": "cross-env APP_ENV=production npm run sync:tokens && expo start",
    "android": "cross-env APP_ENV=development npm run sync:tokens && expo start:android",
    "ios": "cross-env APP_ENV=development expo run:ios",
    "build:android:staging": "cross-env APP_ENV=staging eas build -p android --profile preview",
    "build:android:prod": "cross-env APP_ENV=production eas build -p android --profile production",
    "android:p": "expo start --tunnel --android",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "sync:tokens": "node src/theme/script/sync-tailwind.js",
    "prepare": "husky install"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.4",
    "@expo/vector-icons": "^14.1.0",
    "@faker-js/faker": "^10.0.0",
    "@gorhom/bottom-sheet": "^5.2.4",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.6",
    "@react-navigation/native": "^7.1.17",
    "@supabase/supabase-js": "^2.57.2",
    "@tanstack/query-async-storage-persister": "^5.89.0",
    "@tanstack/react-query": "^5.89.0",
    "@tanstack/react-query-persist-client": "^5.89.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.2",
    "expo": "~53.0.22",
    "expo-auth-session": "~6.2.1",
    "expo-file-system": "~18.1.11",
    "expo-linear-gradient": "~14.1.5",
    "expo-router": "^5.1.5",
    "expo-secure-store": "^15.0.7",
    "expo-sharing": "~13.1.5",
    "expo-status-bar": "~2.2.3",
    "expo-web-browser": "~14.2.0",
    "jotai": "^2.14.0",
    "jotai-utils": "^0.0.0",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-gifted-charts": "^1.4.64",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.20.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "7.25",
    "@eslint/js": "^9.34.0",
    "@types/react": "~19.0.10",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^11.0.15",
    "cross-env": "^10.0.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-expo": "^0.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3",
    "husky": "^8.0.0"
  },
  "private": true
}
